# App Configuration
APP_ENV=development
DEBUG=true
PORT=8000

# Database Credentials (matches docker-compose.yaml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=templatedb
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Connection String (Internal Docker Network)
# Driver: postgresql+asyncpg (since we are using async SQLAlchemy)
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@db:5432/templatedb

# Internal service URLs (in k8s: http://<service>.<namespace>.svc.cluster.local/...)
MEDIA_INGEST_URL=http://localhost:5070/media/api

# GCP / Gemini Config
PROJECT_ID=your-gcp-project-id
LOCATION=us-central1
STORAGE_URI=gs://your-bucket/path
# Path to GCP service account JSON key file (for local dev)
SERVICE_ACCOUNT_KEY_FILE=/path/to/sa-key.json

# Langfuse Prompt Management (self-hosted)
LANGFUSE_SECRET_KEY=sk-lf-69e0b522-43e5-4a27-8fe8-51400c943549
LANGFUSE_PUBLIC_KEY=pk-lf-89f4073a-5680-4a25-a990-37bf2da0a43f
LANGFUSE_HOST=http://langfuse-web:3000