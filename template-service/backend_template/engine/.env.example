# Engine Environment Variables
# Copy this file to .env in the same directory and fill in your values.
# This file is read by config.py (pydantic-settings env_file=".env").

# GCP / Gemini Config
SERVICE_ACCOUNT_KEY_FILE=/path/to/sa-key.json
PROJECT_ID=your-gcp-project-id
LOCATION=us-central1
STORAGE_URI=gs://your-bucket/path

# Internal service URLs
MEDIA_INGEST_URL=http://localhost:5070/media/api