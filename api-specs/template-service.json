        "summary": "Get a single node schema",
        "description": "Returns the schema for a specific node class by name\n(e.g., `GeminiNode`, `VeoVideoGenerationNode`).",
        "operationId": "get_node_v1_engine_nodes__node_class__get",
        "parameters": [
          {
            "name": "node_class",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Node Class"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
