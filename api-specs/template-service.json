          "outputs",
          "status",
          "meta"
        ],
        "title": "HistoryEntry",
        "description": "A single prompt's execution history entry."
      },
      "ProjectTemplateCreate": {
        "properties": {
          "project_id": {
            "type": "string",
            "format": "uuid",
            "title": "Project Id",
            "description": "The UUID of the parent Project this template belongs to."
          },
          "name": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Name",
            "description": "The human-readable name of the template."
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description",
            "description": "Optional description of the template's purpose."
          },
          "current_graph_json": {
            "additionalProperties": true,
            "type": "object",
            "title": "Current Graph Json",
            "description": "The ComfyUI-style node graph definition. Defaults to empty object."
          }
        },
        "type": "object",
        "required": [
          "project_id",
          "name"
        ],
        "title": "ProjectTemplateCreate",
        "description": "Fields required to CREATE a new template.\nInherits everything from Base. \nBody is 'pass' because no extra write-only fields (like passwords) are needed."
      },
      "ProjectTemplateResponse": {
        "properties": {
          "project_id": {
            "type": "string",
            "format": "uuid",
            "title": "Project Id",
            "description": "The UUID of the parent Project this template belongs to."
          },
          "name": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Name",
            "description": "The human-readable name of the template."
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description",
            "description": "Optional description of the template's purpose."
          },
          "current_graph_json": {
            "additionalProperties": true,
            "type": "object",
            "title": "Current Graph Json",
            "description": "The ComfyUI-style node graph definition. Defaults to empty object."
          },
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          }
        },
        "type": "object",
        "required": [
          "project_id",
          "name",
          "id",
          "created_at",
          "updated_at"
        ],
        "title": "ProjectTemplateResponse",
        "description": "The full representation returned to the client.\nInherits from Base (Shared fields) + Adds System fields (ID, Timestamps)."
      },
      "ProjectTemplateUpdate": {
        "properties": {
          "name": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 255,
                "minLength": 1
              },
              {
                "type": "null"
              }
            ],
            "title": "Name"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "current_graph_json": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Current Graph Json"
          }
        },
        "type": "object",
        "title": "ProjectTemplateUpdate",
        "description": "Fields allowed to be UPDATED.\nCRITICAL: Inherits from BaseModel, NOT ProjectTemplateBase.\nAll fields are optional (None) to support PATCH operations."
      },
      "PromptRequest": {
        "properties": {
          "prompt": {
            "additionalProperties": true,
            "type": "object",
            "title": "Prompt",
            "description": "Workflow graph \u2014 dict of node_id \u2192 Node definition."
          },
          "partial_execution_targets": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Partial Execution Targets",
            "description": "Execute only these output nodes (+ upstream deps). Omit to run all OUTPUT_NODE nodes."
          },
          "extra_data": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Extra Data",
            "description": "Arbitrary metadata forwarded to nodes via hidden inputs."
          },
          "number": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Number",
            "description": "Queue priority (lower = higher). Auto-incremented if omitted."
          },
          "front": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Front",
            "description": "Push to front of queue."
          }
        },
        "type": "object",
        "required": [
          "prompt"
        ],
        "title": "PromptRequest",
        "description": "Request body for submitting a workflow graph for execution."
      },
      "PromptResponse": {
        "properties": {
          "prompt_id": {
            "type": "string",
            "title": "Prompt Id"
          },
          "number": {
            "type": "integer",
            "title": "Number"
          },
          "node_errors": {
            "additionalProperties": true,
            "type": "object",
            "title": "Node Errors"
          }
        },
        "type": "object",
        "required": [
          "prompt_id",
          "number",
          "node_errors"
        ],
        "title": "PromptResponse",
        "description": "Successful response from POST /api/prompt."
      },
      "QueueItem": {
        "properties": {
          "number": {
            "type": "number",
            "title": "Number"
          },
          "prompt_id": {
            "type": "string",
            "title": "Prompt Id"
          },
          "prompt": {
            "additionalProperties": true,
            "type": "object",
            "title": "Prompt"
          },
          "extra_data": {
            "additionalProperties": true,
            "type": "object",
            "title": "Extra Data"
          },
          "outputs_to_execute": {
            "items": {
              "type": "string"
            },
