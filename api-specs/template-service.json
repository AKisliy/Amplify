    "/v1/engine/prompt": {
      "post": {
        "tags": [
          "Engine"
        ],
        "summary": "Submit a workflow for execution",
        "description": "Submits a workflow graph for asynchronous execution on the engine.\nReturns immediately with a `prompt_id` \u2014 poll\n`GET /history/{prompt_id}` for results.",
        "operationId": "submit_prompt_v1_engine_prompt_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PromptRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PromptResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/engine/history/{prompt_id}": {
      "get": {
        "tags": [
          "Engine"
        ],
        "summary": "Get execution history for a prompt",
        "description": "Returns the execution history entry for a specific prompt_id.\nReturns null if no history exists for that prompt.",
        "operationId": "get_prompt_history_v1_engine_history__prompt_id__get",
        "parameters": [
          {
            "name": "prompt_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Prompt Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    {
                      "$ref": "#/components/schemas/HistoryEntry"
                    },
                    {
                      "type": "null"
                    }
                  ],
                  "title": "Response Get Prompt History V1 Engine History  Prompt Id  Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/engine/history": {
      "get": {
        "tags": [
          "Engine"
        ],
        "summary": "List execution history",
        "description": "Returns execution history for all prompts.\nSupports optional pagination via `max_items` and `offset`.",
        "operationId": "get_all_history_v1_engine_history_get",
        "parameters": [
          {
            "name": "max_items",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer",
                  "minimum": 1
                },
                {
                  "type": "null"
                }
              ],
              "title": "Max Items"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Offset"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/HistoryEntry"
                  },
                  "title": "Response Get All History V1 Engine History Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Engine"
        ],
        "summary": "Clear or delete history entries",
        "description": "Clears all execution history (if `clear=true`) and/or deletes\nspecific entries by prompt_id (if `delete` list is provided).",
        "operationId": "clear_history_v1_engine_history_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Body_clear_history_v1_engine_history_post"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
