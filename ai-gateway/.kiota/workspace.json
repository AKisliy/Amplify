{
  "version": "1.0.0",
  "clients": {
    "ElevenLabsClient": {
      "language": "CSharp",
      "typeAccessModifier": "Public",
      "structuredMimeTypes": [
        "application/json",
        "text/plain;q=0.9",
        "application/x-www-form-urlencoded;q=0.2",
        "multipart/form-data;q=0.1"
      ],
      "clientNamespaceName": "AiGateway.Web.Clients.ElevenLabs",
      "usesBackingStore": false,
      "includeAdditionalData": true,
      "excludeBackwardCompatible": false,
      "disabledValidationRules": [],
      "descriptionLocation": "https://api.elevenlabs.io/openapi.json",
      "includePatterns": [
        "/v1/speech-to-speech",
        "/v1/speech-to-speech/{voice_id}",
        "/v1/speech-to-speech/{voice_id}/stream"
      ],
      "excludePatterns": [],
      "outputPath": "./src/Web/Clients"
    }
  },
  "plugins": {}
}