{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore.SpaProxy": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Jwt" : {
    "Issuer": "https://localhost:5001/userservice/api/auth",
    "Audience": "MyAppDevelopmentUsers"
  },
  "S3": {
    "Host": "localhost:9000",
    "AccessKey": "admin",
    "SecretKey": "password",
    "BucketName": "media",
    "PublicBucketUrl": "http://localhost:9000/media"
  },
  "YtDlp": {
    "YoutubeDlPath": "/opt/homebrew/bin/yt-dlp"
  },
  "DbConnection": {
    "Default": "Host=localhost;Port=6432;Database=myDb;Username=dev_user;Password=dev_password"
  },
  "MediaIngest": {
    "BasePath": "/media"
  },
  "RabbitMQ": {
    "Url": "amqp://guest:guest@localhost:5672"
  },
  "CorsOptions": {
    "DefaultPolicyName": "DevelopmentCorsPolicy",
    "AllowedOrigins": [ "http://localhost:3000" ]
  }
}
